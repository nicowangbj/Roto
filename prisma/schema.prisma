generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects      Project[]
  conversations Conversation[]
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String   @default("未命名项目")
  description String?
  status      String   @default("topic_selection") // topic_selection, planning, executing, adjusting, completed, archived
  topicId     String?  @unique
  topic       Topic?   @relation(fields: [topicId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phases        Phase[]
  journalEntries JournalEntry[]
  conversations  Conversation[]
}

model Topic {
  id             String  @id @default(cuid())
  name           String
  field          String? // research field
  description    String?
  outputFormat   String? // paper, report, experiment log, etc.
  duration       String? // e.g., "12 weeks"
  weeklyHours    String? // e.g., "5 hours"
  userProfile    String? // user profile generated by AI
  keywords       String? // JSON array of selected keywords
  selectedPath   String  @default("no_topic") // has_topic, no_topic
  confirmed      Boolean @default(false)
  createdAt      DateTime @default(now())

  project Project?
}

model Phase {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  order       Int      // order in the project
  name        String
  description String?
  goal        String?
  status      String   @default("locked") // locked, active, completed
  startWeek   Int?
  endWeek     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks Task[]
}

model Task {
  id            String   @id @default(cuid())
  phaseId       String
  phase         Phase    @relation(fields: [phaseId], references: [id])
  order         Int
  title         String
  description   String?
  explanation   String?  // pre-generated explanation content (AI-S12)
  weekNumber    Int?     // which week this task belongs to
  status        String   @default("locked") // locked, active, submitted, graded, completed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  submissions Submission[]
}

model Submission {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  content     String   // user's submission content
  version     Int      @default(1) // 1 = first submission, 2+ = resubmission
  grade       String?  // A, B, C, D
  feedback    String?  // AI feedback
  suggestions String?  // JSON: improvement suggestions for each grade level
  hintUsed    Boolean  @default(false) // whether hint was used
  hintContent String?  // hint template content if used
  maxGrade    String   @default("A") // max possible grade (C if hint was used)
  createdAt   DateTime @default(now())
}

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  strategyId String?  // which AI strategy this conversation uses
  context    String?  // additional context (JSON)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String       // user, assistant, system
  content        String
  createdAt      DateTime     @default(now())
}

model JournalEntry {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  title     String
  content   String   // first-person narrative
  source    String   // what triggered this entry: task_complete, phase_complete, plan_adjust, etc.
  sourceId  String?  // ID of the source (task ID, phase ID, etc.)
  weekNumber Int?
  createdAt DateTime @default(now())
}

model AIStrategy {
  id          String   @id @default(cuid())
  code        String   @unique // AI-S01, AI-S02, etc.
  name        String
  module      String   // topic_selection, plan_display, plan_execution, plan_adjustment, journal
  strategyType String  @default("generation") // conversation, generation, evaluation, computation
  description String?
  triggerTiming String?
  promptTemplate String @default("") // the actual prompt template
  inputSchema String?  // JSON schema for expected input
  outputSchema String? // JSON schema for expected output
  isConfigured Boolean @default(false) // false = placeholder, true = configured
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
